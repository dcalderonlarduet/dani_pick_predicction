# Tenis: odds-api-io (solo ODDS_API_IO_KEY) o matchstat (stats + cuotas)
TENNIS_DATA_PROVIDER=odds-api-io
TENNIS_ODDS_PROVIDER=odds-api-io

MATCHSTAT_RAPIDAPI_KEY=
MATCHSTAT_RAPIDAPI_HOST=tennis-api-atp-wta-itf.p.rapidapi.com
MATCHSTAT_BASE_URL=https://tennis-api-atp-wta-itf.p.rapidapi.com
MATCHSTAT_TOURS=atp,wta
MATCHSTAT_FIXTURE_INCLUDES=round,tournament,tournament.court,tournament.rank,h2h
MATCHSTAT_PLAYER_GROUP=singles
MATCHSTAT_PAGE_SIZE=20
MATCHSTAT_RANKINGS_PAGE_SIZE=200
MATCHSTAT_RECENT_MATCHES_PAGE_SIZE=12

# Cuotas (recomendado): https://docs.odds-api.io/
ODDS_API_IO_KEY=
ODDS_API_IO_BOOKMAKERS=Bet365,Winamax FR
ODDS_API_IO_BASE_URL=https://api.odds-api.io/v3
MLB_ODDS_PROVIDER=odds-api-io
TENNIS_ODDS_PROVIDER=odds-api-io

# Alternativa legacy
THE_ODDS_API_KEY=
THE_ODDS_REGIONS=eu,uk
THE_ODDS_MARKETS=h2h,spreads,totals

ESPN_SCOREBOARD_ENABLED=true
ESPN_TENNIS_LEAGUES=atp,wta

SPORTDEVS_ENABLED=false
SPORTDEVS_API_KEY=
SPORTDEVS_RAPIDAPI_KEY=
SPORTDEVS_RAPIDAPI_HOST=
SPORTDEVS_BASE_URL=https://tennis.sportdevs.com
SPORTDEVS_LANG=en
SPORTDEVS_RANKINGS_LIMIT=200
SPORTDEVS_MATCHES_LIMIT=100

API_TENNIS_API_KEY=
SPORTRADAR_API_KEY=
SPORTRADAR_ACCESS_LEVEL=trial
SPORTRADAR_LANGUAGE=en

TENNIS_TIMEZONE=Europe/Madrid
TENNIS_MAX_MATCHES=12
TENNIS_RECENT_WINDOW_DAYS=120
TENNIS_DROP_MIN=5

# Politica EV (tenis; futbol usa FOOTBALL_*)
EV_THRESHOLD=0.05
MIN_ODDS=1.40
MAX_ODDS=3.00
MIN_CONFIDENCE=60
PARLAY_MIN_ODDS=1.80
PARLAY_MAX_ODDS=4.00

# Futbol (Odds-API.io value-bets + dropping-odds)
FOOTBALL_MAX_MATCHES=12
FOOTBALL_EV_THRESHOLD=0.05
FOOTBALL_MIN_ODDS=1.40
FOOTBALL_MAX_ODDS=3.40
FOOTBALL_MIN_CONFIDENCE=60
FOOTBALL_DROP_MIN=8
PICK_MODE=value
FOOTBALL_VALUE_EV_MIN=0.04
FOOTBALL_VALUE_CONF_MIN=45
MLB_VALUE_EV_MIN=0.03
MLB_VALUE_EDGE_MIN=0.025

# Refuerzo futbol (API-Sports free plan)
APISPORTS_FOOTBALL_ENABLED=false
APISPORTS_FOOTBALL_KEY=
APISPORTS_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
APISPORTS_FOOTBALL_TIMEZONE=Europe/Madrid
APISPORTS_FOOTBALL_REFRESH_MINUTES=25
APISPORTS_FOOTBALL_DISCOVERY_MINUTES=360
APISPORTS_FOOTBALL_DETAIL_BUDGET=1

# Refuerzo NBA/NFL (API-Sports — fallback silencioso si ESPN incompleto)
APISPORTS_BASKETBALL_ENABLED=false
APISPORTS_BASKETBALL_KEY=
APISPORTS_BASKETBALL_BASE_URL=https://v1.basketball.api-sports.io
APISPORTS_BASKETBALL_LEAGUE_ID=12
APISPORTS_AMERICAN_FOOTBALL_ENABLED=false
APISPORTS_AMERICAN_FOOTBALL_KEY=
APISPORTS_AMERICAN_FOOTBALL_BASE_URL=https://v1.american-football.api-sports.io
APISPORTS_AMERICAN_FOOTBALL_LEAGUE_ID=1

NBA_MIN_ODDS=1.72
NBA_MAX_ODDS=2.35
NFL_MIN_ODDS=1.72
NFL_MAX_ODDS=2.35

FLASHSCORE_SNAPSHOT_FILE=src/data/community/flashscore-live.snapshot.example.json
ODDSHARVESTER_SNAPSHOT_FILE=src/data/community/oddsharvester.snapshot.example.json

# Telegram notifications (tracker picks: TOP verde + ALTERNATIVA amarillo)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
